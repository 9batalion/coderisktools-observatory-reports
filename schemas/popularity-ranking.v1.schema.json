{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://9batalion.github.io/coderisktools-observatory-reports/schemas/popularity-ranking.v1.schema.json",
  "title": "CodeRiskTools popularity cohort scan coverage",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "week", "cohort", "provenance", "publication", "entries", "limitations"],
  "properties": {
    "schema": {"const": "coderisktools.observatory.popularity-ranking.v1"},
    "week": {"type": "string", "pattern": "^[0-9]{4}-W[0-9]{2}$"},
    "cohort": {
      "type": "object", "additionalProperties": false,
      "required": ["schema", "metric", "snapshot_at", "tie_break", "size"],
      "properties": {
        "schema": {"const": "coderisktools.public-popularity-cohort.v1"},
        "metric": {"const": "stargazers_count"},
        "snapshot_at": {"type": "string", "format": "date-time"},
        "tie_break": {"const": "repository lexicographic ascending"},
        "size": {"const": 15}
      }
    },
    "provenance": {
      "type": "object", "additionalProperties": false,
      "required": ["scanner_version", "scanner_source_commit", "ruleset_digest"],
      "properties": {
        "scanner_version": {"const": "3.0.1"},
        "scanner_source_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "ruleset_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
      }
    },
    "publication": {
      "type": "object", "additionalProperties": false,
      "required": ["purpose", "security_ranking", "raw_findings", "firewall_results"],
      "properties": {
        "purpose": {"const": "POPULARITY_COHORT_SCAN_COVERAGE"},
        "security_ranking": {"const": false},
        "raw_findings": {"const": "NOT_PUBLISHED"},
        "firewall_results": {"const": "NOT_PUBLISHED"}
      }
    },
    "entries": {
      "type": "array", "minItems": 15, "maxItems": 15,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["rank", "repository", "repository_url", "head_sha", "stars", "license_spdx", "scan_status", "publication_status"],
        "properties": {
          "rank": {"type": "integer", "minimum": 1, "maximum": 15},
          "repository": {"type": "string", "pattern": "^[A-Za-z0-9_.-]{1,39}/[A-Za-z0-9_.-]{1,100}$"},
          "repository_url": {"type": "string", "format": "uri"},
          "head_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
          "stars": {"type": "integer", "minimum": 0},
          "license_spdx": {"type": ["string", "null"]},
          "scan_status": {"enum": ["complete", "partial"]},
          "publication_status": {"const": "NOT_PUBLISHED"}
        }
      }
    },
    "limitations": {"type": "array", "minItems": 3, "maxItems": 3, "items": {"type": "string"}}
  }
}
