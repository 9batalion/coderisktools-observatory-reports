{
  "schema": "coderisktools.observatory.reports-repository-policy.v1",
  "repository": {
    "visibility": "public",
    "default_branch": "main",
    "pages_source": "github_actions"
  },
  "branch_protection": {
    "required_pull_request_reviews": true,
    "required_approving_review_count": 1,
    "dismiss_stale_reviews": true,
    "require_code_owner_reviews": true,
    "required_status_checks": ["validate"],
    "strict_status_checks": true,
    "enforce_admins": true,
    "allow_force_pushes": false,
    "allow_deletions": false
  },
  "publisher_identity": {
    "type": "dedicated_github_app_or_machine_user",
    "can_open_report_pull_requests": true,
    "can_push_main": false,
    "can_approve_own_pull_request": false,
    "can_modify_engine_repository": false,
    "can_modify_scanner_or_firewall": false
  },
  "pages_environment": {
    "name": "github-pages",
    "required_reviewers": 1,
    "prevent_self_review": true
  },
  "attestation": {
    "subject": "public/SHA256SUMS.txt",
    "meaning": "OIDC provenance for the exact complete-tree manifest; the manifest closes every deployed public byte",
    "required_before_deploy": true
  },
